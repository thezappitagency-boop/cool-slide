ze:18px;'><span>Baths</span>4</div><div class='il-detail-item' style='font-size:18px;'><span>Price</span>$875k</div></div></div></div><div class='il-property-card'><a href='#' class='il-property-card-image' style='display:block;overflow:hidden;'><div style='background:#e0e0e0;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;transition:transform .5s;'><p style='font-family:var(--font-label);font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#bbb;margin:0;'>Property Image</p></div></a><div class='il-property-card-info' style='padding:20px 0 0;'><h3 class='il-property-title' style='font-size:32px;margin-bottom:4px;'>Loft Hist\u00f3rico</h3><p style='font-family:var(--font-label);font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:rgba(0,0,0,.4);margin:4px 0 14px;'>Old Mazatl\u00e1n</p><div style='display:flex;gap:24px;'><div class='il-detail-item' style='font-size:18px;'><span>Beds</span>1</div><div class='il-detail-item' style='font-size:18px;'><span>Baths</span>1</div><div class='il-detail-item' style='font-size:18px;'><span>Price</span>$165k</div></div></div></div><div class='il-property-card'><a href='#' class='il-property-card-image' style='display:block;overflow:hidden;'><div style='background:#d8d8d8;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;transition:transform .5s;'><p style='font-family:var(--font-label);font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#bbb;margin:0;'>Property Image</p></div></a><div class='il-property-card-info' style='padding:20px 0 0;'><h3 class='il-property-title' style='font-size:32px;margin-bottom:4px;'>Residencia Pacifico</h3><p style='font-family:var(--font-label);font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:rgba(0,0,0,.4);margin:4px 0 14px;'>Cerritos, Mazatl\u00e1n</p><div style='display:flex;gap:24px;'><div class='il-detail-item' style='font-size:18px;'><span>Beds</span>3</div><div class='il-detail-item' style=