        {
          "id": "arwgt001",
          "elType": "widget",
          "widgetType": "html",
          "settings": {
            "html": "<div><h1 class='il-title is-accent'><span><i></i>Mazatl\u00e1n Real Estate</span>All Listings</h1><p class='il-body-text' style='max-width:560px;margin-top:28px;'>Browse our curated collection of premium real estate in Mazatl\u00e1n, Sinaloa. From oceanfront estates to urban condos and investment properties. <em>Replace with ACF or Elementor dynamic tag for the archive subtitle.</em></p></div>"
